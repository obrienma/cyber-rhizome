---
import Layout from '../components/Layout.astro';
---

<Layout title="contact" description="Get in touch.">
  <header class="mb-10">
    <h1 class="font-mono text-rz-text text-lg mb-2">contact</h1>
    <p class="text-sm text-rz-muted max-w-sm">
      Send me a message. I read everything, reply when I have something useful to say.
    </p>
  </header>

  <!--
    Formspree setup:
    1. Create a free account at formspree.io
    2. Create a new form and copy your form ID
    3. Replace YOUR_FORM_ID below
  -->
  <form
    action="https://formspree.io/f/YOUR_FORM_ID"
    method="POST"
    class="space-y-6 max-w-sm"
    id="contact-form"
  >
    <div class="space-y-1.5">
      <label for="name" class="font-mono text-xs text-rz-muted block">name</label>
      <input
        type="text"
        id="name"
        name="name"
        required
        autocomplete="name"
        class="w-full bg-rz-surface border border-rz-border rounded px-3 py-2 font-mono text-sm text-rz-text placeholder:text-rz-muted/50 focus:outline-none focus:border-rz-accent/60 transition-colors"
        placeholder="your name"
      />
    </div>

    <div class="space-y-1.5">
      <label for="email" class="font-mono text-xs text-rz-muted block">email</label>
      <input
        type="email"
        id="email"
        name="email"
        required
        autocomplete="email"
        class="w-full bg-rz-surface border border-rz-border rounded px-3 py-2 font-mono text-sm text-rz-text placeholder:text-rz-muted/50 focus:outline-none focus:border-rz-accent/60 transition-colors"
        placeholder="you@example.com"
      />
    </div>

    <div class="space-y-1.5">
      <label for="message" class="font-mono text-xs text-rz-muted block">message</label>
      <textarea
        id="message"
        name="message"
        required
        rows="6"
        class="w-full bg-rz-surface border border-rz-border rounded px-3 py-2 font-mono text-sm text-rz-text placeholder:text-rz-muted/50 focus:outline-none focus:border-rz-accent/60 transition-colors resize-none leading-relaxed"
        placeholder="what's on your mind"
      ></textarea>
    </div>

    <button
      type="submit"
      class="font-mono text-sm px-4 py-2 rounded border border-rz-accent/40 text-rz-accent hover:bg-rz-accent/10 transition-colors duration-150 cursor-pointer"
    >
      send →
    </button>

    <p id="form-success" class="hidden font-mono text-xs text-rz-accent">
      message sent. i'll be in touch.
    </p>
    <p id="form-error" class="hidden font-mono text-xs text-red-400">
      something went wrong. try again or email me directly.
    </p>
  </form>
</Layout>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const success = document.getElementById('form-success');
  const error = document.getElementById('form-error');

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = new FormData(form);

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: data,
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.reset();
        success?.classList.remove('hidden');
      } else {
        error?.classList.remove('hidden');
      }
    } catch {
      error?.classList.remove('hidden');
    }
  });
</script>
