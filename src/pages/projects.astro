---
import { getCollection } from 'astro:content';
import Layout from '../components/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import TagPill from '../components/TagPill.astro';

const allProjects = await getCollection('projects');

// Collect all unique tags
const allTags = [...new Set(allProjects.flatMap(p => p.data.tags))].sort();
---

<Layout title="projects" description="Things I've built — software, and otherwise.">
  <header class="mb-10">
    <h1 class="font-mono text-rz-text text-lg mb-2">projects</h1>
    <p class="text-sm text-rz-muted">
      Software and otherwise. Same format, same tags — no artificial separation.
    </p>
  </header>

  <!-- Tag filter -->
  {allTags.length > 0 && (
    <div id="tag-filters" class="flex flex-wrap gap-2 mb-10">
      <button
        data-tag="all"
        class="font-mono text-xs px-2 py-0.5 rounded border border-rz-accent/40 bg-rz-accent/10 text-rz-accent transition-colors duration-150 cursor-pointer"
      >
        all
      </button>
      {allTags.map(tag => (
        <TagPill tag={tag} interactive={true} />
      ))}
    </div>
  )}

  <!-- Project list -->
  <div id="project-list">
    {allProjects.map(project => (
      <article
        data-tags={project.data.tags.join(',')}
        class="contents"
      >
        <ProjectCard
          title={project.data.title}
          description={project.data.description}
          url={project.data.url}
          tags={project.data.tags}
          status={project.data.status}
        />
      </article>
    ))}
  </div>

  <p id="no-results" class="hidden font-mono text-sm text-rz-muted py-8">
    no projects with that tag.
  </p>
</Layout>

<script>
  const filterButtons = document.querySelectorAll<HTMLButtonElement>('#tag-filters [data-tag]');
  const projects = document.querySelectorAll<HTMLElement>('#project-list article[data-tags]');
  const noResults = document.getElementById('no-results');

  function setActive(btn: HTMLButtonElement) {
    filterButtons.forEach(b => {
      b.classList.remove('bg-rz-accent/10', 'text-rz-accent', 'border-rz-accent/40');
      b.classList.add('text-rz-muted', 'border-rz-border');
    });
    btn.classList.add('bg-rz-accent/10', 'text-rz-accent', 'border-rz-accent/40');
    btn.classList.remove('text-rz-muted', 'border-rz-border');
  }

  filterButtons.forEach(btn => {
    btn.addEventListener('click', () => {
      const tag = btn.dataset.tag!;
      setActive(btn);

      let visible = 0;
      projects.forEach(project => {
        const tags = (project.dataset.tags ?? '').split(',');
        const show = tag === 'all' || tags.includes(tag);
        project.style.display = show ? '' : 'none';
        if (show) visible++;
      });

      noResults?.classList.toggle('hidden', visible > 0);
    });
  });
</script>
