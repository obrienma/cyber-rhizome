---
import { getCollection } from 'astro:content';
import Layout from '../components/Layout.astro';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const recentPosts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const allProjects = await getCollection('projects');
const featuredProjects = allProjects.filter(p => p.data.featured);

function fmtDate(d: Date) {
  return `${d.getFullYear()}.${String(d.getMonth() + 1).padStart(2, '0')}.${String(d.getDate()).padStart(2, '0')}`;
}
---

<Layout title="cyber-rhizome">

  <!-- Intro -->
  <section class="mb-20">
    <p class="font-mono text-[11px] text-rz-muted/60 tracking-widest uppercase mb-5">
      software engineer
    </p>

    <p class="text-[15px] text-rz-text leading-[1.8] max-w-[400px] mb-4">
      I build distributed systems and write about what I learn.
    </p>
    <p class="text-[14px] text-rz-muted leading-[1.8] max-w-[400px]">
      Also: fermenting things in jars, sewing clothes that fit.
      This site is where those threads connect.
    </p>

    <div class="flex items-center gap-5 font-mono text-xs text-rz-muted mt-8">
      <a href="/blog"     class="nav-pill">writing</a>
      <a href="/projects" class="nav-pill">projects</a>
      <a href="/contact"  class="nav-pill">contact</a>
    </div>
  </section>

  <!-- Recent Writing -->
  {recentPosts.length > 0 && (
    <section class="mb-16">
      <div class="section-head">
        <span class="slash">//</span> recent writing
      </div>

      <ul class="log-list">
        {recentPosts.map(post => (
          <li>
            <a href={`/blog/${post.id}`} class="log-row">
              <time class="log-date">{fmtDate(post.data.date)}</time>
              <span class="log-title">{post.data.title}</span>
              <span class="log-meta">{post.data.tags.slice(0, 2).join(', ')}</span>
            </a>
          </li>
        ))}
      </ul>

      <a href="/blog" class="see-more">all writing</a>
    </section>
  )}

  <!-- Featured Projects -->
  {featuredProjects.length > 0 && (
    <section>
      <div class="section-head">
        <span class="slash">//</span> selected work
      </div>

      <ul class="log-list">
        {featuredProjects.map(project => (
          <li>
            {project.data.url ? (
              <a href={project.data.url} target="_blank" rel="noopener noreferrer" class="log-row">
                <span class:list={['log-date', `status-${project.data.status}`]}>
                  {project.data.status}
                </span>
                <span class="log-title">{project.data.title}</span>
                <span class="log-meta">
                  {project.data.tags.filter(t => t !== 'dev').slice(0, 2).join(', ')}
                </span>
              </a>
            ) : (
              <div class="log-row no-link">
                <span class:list={['log-date', `status-${project.data.status}`]}>
                  {project.data.status}
                </span>
                <span class="log-title">{project.data.title}</span>
                <span class="log-meta">
                  {project.data.tags.filter(t => t !== 'dev').slice(0, 2).join(', ')}
                </span>
              </div>
            )}
          </li>
        ))}
      </ul>

      <a href="/projects" class="see-more">all projects</a>
    </section>
  )}

</Layout>

<style>
  /* Section header: // label */
  .section-head {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 0.68rem;
    color: #6b7280;
    letter-spacing: 0.05em;
    margin-bottom: 1rem;
    user-select: none;
  }

  .slash {
    color: #4db6ac;
    opacity: 0.65;
    margin-right: 0.3rem;
  }

  /* Tabular log layout — reads like a file listing */
  .log-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .log-row {
    display: grid;
    grid-template-columns: 7.5rem 1fr auto;
    align-items: baseline;
    column-gap: 1.25rem;
    padding: 0.55rem 0;
    border-bottom: 1px solid #1c1c1c;
    text-decoration: none;
    transition: none;
  }

  a.log-row:hover .log-title { color: #4db6ac; }
  a.log-row:hover .log-date  { color: #9ca3af; }

  .log-date {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 0.68rem;
    color: #4b5563;
    white-space: nowrap;
    transition: color 0.15s;
  }

  .log-title {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 0.78rem;
    color: #e5e5e5;
    transition: color 0.15s;
  }

  .log-meta {
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 0.63rem;
    color: #374151;
    text-align: right;
    white-space: nowrap;
  }

  /* Status colours for projects */
  .status-active      { color: #4db6ac; opacity: 0.55; }
  .status-in-progress { color: #fbbf24; opacity: 0.65; }
  .status-archived    { color: #4b5563; }

  .no-link { cursor: default; }

  /* "all writing" / "all projects" link */
  .see-more {
    display: inline-flex;
    align-items: center;
    gap: 0.375rem;
    font-family: 'JetBrains Mono Variable', monospace;
    font-size: 0.68rem;
    color: #4b5563;
    text-decoration: none;
    margin-top: 0.875rem;
    transition: color 0.15s;
  }

  .see-more::after {
    content: '→';
    color: #4db6ac;
    opacity: 0;
    transition: opacity 0.2s, transform 0.2s;
    transform: translateX(-3px);
    display: inline-block;
  }

  .see-more:hover {
    color: #9ca3af;
  }

  .see-more:hover::after {
    opacity: 0.7;
    transform: translateX(0);
  }

  /* Intro nav pills */
  .nav-pill {
    position: relative;
    color: #6b7280;
    text-decoration: none;
    transition: color 0.15s;
  }

  .nav-pill::after {
    content: '→';
    margin-left: 0.25rem;
    color: #4db6ac;
    opacity: 0;
    transition: opacity 0.15s;
  }

  .nav-pill:hover {
    color: #e5e5e5;
  }

  .nav-pill:hover::after {
    opacity: 0.6;
  }
</style>
