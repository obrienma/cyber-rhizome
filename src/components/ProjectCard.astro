---
import TagPill from './TagPill.astro';

interface Props {
  title: string;
  description: string;
  url?: string;
  tags: string[];
  status: 'active' | 'in-progress' | 'archived';
}

const { title, description, url, tags, status } = Astro.props;

const statusLabel: Record<string, string> = {
  active: 'active',
  'in-progress': 'in progress',
  archived: 'archived',
};

const statusColor: Record<string, string> = {
  active: 'text-rz-accent',
  'in-progress': 'text-yellow-500',
  archived: 'text-rz-muted',
};
---

<article class="py-6 border-b border-rz-border last:border-0">
  <div class="flex items-start justify-between gap-4 mb-2">
    <div>
      {url ? (
        <a
          href={url}
          target="_blank"
          rel="noopener noreferrer"
          class="font-mono text-sm text-rz-text hover:text-rz-accent transition-colors duration-150"
        >
          {title}
          <span class="text-rz-muted ml-1">↗</span>
        </a>
      ) : (
        <span class="font-mono text-sm text-rz-text">{title}</span>
      )}
    </div>
    <span class={`font-mono text-xs shrink-0 ${statusColor[status]}`}>
      {statusLabel[status]}
    </span>
  </div>

  <p class="text-sm text-rz-muted leading-relaxed mb-3">{description}</p>

  <div class="flex flex-wrap gap-1.5">
    {tags.map(tag => <TagPill tag={tag} />)}
  </div>
</article>
